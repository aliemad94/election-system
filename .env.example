# ============================================
# Electoral Machine Management System
# Environment Variables Configuration
# ============================================

# ---- REQUIRED ----
# JWT Secret for signing authentication tokens (MUST be at least 32 characters)
# Generate with: openssl rand -base64 48
JWT_SECRET=

# Admin password for the system owner (MUST be at least 8 characters with letters and numbers)
ADMIN_PASSWORD=

# User password for observer/key_user accounts (MUST be at least 8 characters with letters and numbers)
USER_PASSWORD=

# ---- DATABASE ----
# Database URL (PostgreSQL for production, SQLite for development)
# PostgreSQL example: postgresql://user:password@host:5432/dbname?schema=public
# SQLite example: file:./dev.db
DATABASE_URL=

# ---- OPTIONAL ----
# Node environment
NODE_ENV=production

# Port
PORT=3000
