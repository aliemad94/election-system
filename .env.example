# ════════════════════════════════════════════════════════════════════
# منظومة الماكينة الانتخابية الموحّدة — نموذج متغيرات البيئة
# انسخ هذا الملف إلى .env واملأ القيم. لا تضع أسرارًا حقيقية في المستودع.
# ════════════════════════════════════════════════════════════════════

# ─── قاعدة البيانات ───
# للتطوير المحلي (SQLite) — استخدم prisma/schema.sqlite.prisma:
#   DATABASE_URL="file:./db/custom.db"
#
# للإنتاج (PostgreSQL / Supabase) — استخدم prisma/schema.postgres.prisma:
#   DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require"
#   DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB"   # للترحيلات (migrations) فقط
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ─── الأمان والمصادقة ───
# ولّد مفتاحًا عشوائيًا قويًا:
#   node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET="CHANGE_ME_USE_A_LONG_RANDOM_SECRET"

# ─── كلمات مرور البذور (Seed) — تُستخدم مرة واحدة عند التهيئة، غيّرها فورًا ───
# المستخدمون يُجبَرون على تغيير كلمة المرور عند أول دخول (mustChangePwd).
ADMIN_PASSWORD="CHANGE_ME_STRONG_ADMIN_PASSWORD"
USER_PASSWORD="CHANGE_ME_STRONG_USER_PASSWORD"

# ─── البيئة ───
NODE_ENV="development"

# ─── تجاوز المصادقة في التطوير فقط (لا يعمل في الإنتاج) ───
# اضبطه على "true" فقط أثناء التطوير المحلي لتخطّي تسجيل الدخول.
# BYPASS_AUTH="true"

# ─── (اختياري) Redis لمزامنة الجلسات/الأحداث ───
# REDIS_URL="redis://localhost:6379"
