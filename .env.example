# ============================================
# Electoral Machine Management System
# Environment Variables Configuration
# ============================================

# ---- REQUIRED ----
# JWT Secret for signing authentication tokens (MUST be at least 32 characters)
# Generate with: openssl rand -base64 48
JWT_SECRET=[REDACTED] Admin password for the system owner (MUST be at least 8 characters with letters and numbers)
ADMIN_PASSWORD=[REDACTED] User password for observer/key_user accounts (MUST be at least 8 characters with letters and numbers)
USER_PASSWORD=[REDACTED] ---- DATABASE ----
# Database URL (PostgreSQL for production, SQLite for development)
# PostgreSQL example: postgresql://[REDACTED]
# SQLite example: file:./dev.db
DATABASE_URL=[REDACTED] ---- OPTIONAL ----
# Node environment
NODE_ENV=production

# Port
PORT=3000
