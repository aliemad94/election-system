// ====================================================================
// منظومة الماكينة الانتخابية المركزية — محافظة ذي قار
// Central Electoral Machine Management System — Dhi Qar Governorate
// ====================================================================
// ملاحظة: نسخة SQLite للـ staging. الحقول Json مدعومة عبر Prisma
// كنص JSON. عند الترحيل إلى PostgreSQL الإنتاجي يبقى المخطط متطابقاً.
// ====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// ====================================================================
// المستخدمون وسجل التدقيق
// ====================================================================

model User {
  id            String   @id @default(cuid())
  username      String   @unique
  password      String   // مشفّرة بـ bcryptjs
  role          String   // ADMIN | KEY_USER | OBSERVER
  mustChangePwd Boolean  @default(false) // إجبار تغيير كلمة المرور عند أول دخول
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  auditLogs AuditLog[]

  @@index([role])
}

// سجل التدقيق — يلتقط كل عملية تحويلية مع IP والمستخدم
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  username  String
  action    String   // LOGIN | LOGOUT | CREATE | UPDATE | DELETE | CHANGE_PASSWORD | TOGGLE_ACCESS
  entity    String?  // Tribe | Voter | ElectionKey | Service | ...
  entityId  String?
  details   String?  // JSON string (توافق SQLite)
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([entity, entityId])
}

// ====================================================================
// الهيكلة العشائرية الهرمية
// ====================================================================

// العشيرة الرئيسية
model Tribe {
  id              String        @id @default(cuid())
  name            String        @unique // الاسم الموحّد للعشيرة
  description     String?
  district        String?       // القضاء الذي تتواجد فيه
  influenceRating Int           @default(3) // تصنيف التأثير (1-5)
  population      Int?          // التعداد التقريبي
  notes           String?
  subTribes       SubTribe[]
  voters          Voter[]
  electionKeys    ElectionKey[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @default(now()) @updatedAt

  @@index([district])
  @@index([influenceRating])
}

// الفخذ أو البيت داخل العشيرة
model SubTribe {
  id           String        @id @default(cuid())
  name         String
  tribeId      String
  tribe        Tribe         @relation(fields: [tribeId], references: [id])
  voters       Voter[]
  electionKeys ElectionKey[]

  @@unique([name, tribeId])
  @@index([tribeId])
}

// ====================================================================
// المفتاح الانتخابي (ElectionKey) — محور المنظومة
// ====================================================================

model ElectionKey {
  id              String      @id @default(cuid())
  keyCode         String      @unique // كود رقمي لكل مفتاح
  firstName       String
  fatherName      String
  grandfatherName String
  fourthName      String
  gender          String      // ذكر | أنثى
  birthDate       DateTime
  education       String
  profession      String
  phone           String      @unique
  socialMedia     String?     // JSON string
  province        String      @default("ذي قار")
  district        String      @default("الغراف")
  subDistrict     String
  pollingCenter   String      // مركز الاقتراع
  expectedVotes   Int         @default(0)
  influenceLevel  Int         @default(1) // (1-5)
  mobilizationCap Int         @default(1) // (1-5)
  loyaltyScore    Int         @default(3) // (1-5)
  riskLevel       Int         @default(1) // (1-5)

  // محرك المعايرة الذكية لنسب الانحياز (Dynamic Calibration Engine)
  keyAccuracyScore Float      @default(1.0) // معامل الدقة التاريخية (0.0 - 1.0)
  reliabilityLogs  String?    // JSON string — منحنى دقة تقارير المفتاح

  // === حقول إضافية من النسخة القديمة للتوافق الشامل ===
  nickname         String?
  phone2           String?
  email            String?
  address          String?
  neighborhood     String?
  pollingStation   String?
  age              Int?
  specialization   String?
  maritalStatus    String?
  familySize       Int?
  notes            String?
  isActive         Boolean    @default(true)
  firstContactDate DateTime?
  lastContactDate  DateTime?
  lastSpentDate    DateTime?
  trainingStatus   String?
  dataAccuracy     String?
  createdBy        String?

  // حقول القوة الانتخابية والتصويت التفصيلية
  totalVotes       Int        @default(0)
  supportedVotes   Int        @default(0)
  neutralVotes     Int        @default(0)
  weakVotes        Int        @default(0)
  netVotes         Int        @default(0)

  // تسعة أبعاد تقييمية (تقييم من 1-5)
  voteProtection     Int      @default(3) // القدرة على حماية الأصوات
  supportReason      Int      @default(3) // أسباب الدعم
  needsLevel         Int      @default(3) // الاحتياجات
  politicalNote      Int      @default(3) // الملاحظات السياسية
  organizationalNote Int      @default(3) // الملاحظات التنظيمية
  generalNote        Int      @default(3) // الملاحظات العامة

  // النتيجة النهائية الموزونة والتصنيف
  weightedScore      Float      @default(0.0)
  classification     String     @default("مقبول") // ضعيف / مقبول / جيد / قوي

  // المؤشرات المركبة المتقدمة
  eiiScore           Float      @default(0.0)
  kriScore           Float      @default(0.0)
  vpsScore           Float      @default(0.0)
  drsScore           Float      @default(0.0)
  campaignROI        Float      @default(0.0)

  // حقول مالية للمؤشرات
  totalSpent         Float      @default(0.0)
  monthlyBudget      Float      @default(0.0)
  totalInvestment    Float      @default(0.0)
  costPerVote        Float      @default(0.0)

  tribeId    String?
  tribe      Tribe?     @relation(fields: [tribeId], references: [id])
  subTribeId String?
  subTribe   SubTribe?  @relation(fields: [subTribeId], references: [id])

  voters        Voter[]
  services      Service[]
  earlyWarnings EarlyWarning[]
  tasks         Task[]         @relation("ElectionKeyTasks")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tribeId])
  @@index([subTribeId])
  @@index([province])
  @@index([district])
  @@index([influenceLevel])
  @@index([isActive])
  @@index([classification])
  @@index([weightedScore])
}

// ====================================================================
// الناخب (Voter) — Micro-Targeting + Floating Voters Clustering
// ====================================================================

model Voter {
  id              String      @id @default(cuid())
  firstName       String
  fatherName      String
  grandfatherName String
  fourthName      String
  gender          String      // ذكر | أنثى
  birthDate       DateTime
  phone           String?
  education       String?
  profession      String?
  specialization  String?
  maritalStatus   String?
  familySize      Int?
  nationalId      String?
  area            String?
  socialMedia     String?     // JSON string
  firstContactDate DateTime?
  province        String      @default("ذي قار")
  district        String      @default("الغراف")
  subDistrict     String
  pollingCenter   String      // مركز الاقتراع الكلي
  ballotStation   String      // رقم المحطة الدقيق (Micro-Targeting)
  status          String      @default("NEUTRAL") // SUPPORTED | NEUTRAL | WEAK
  supportDegree   Int         @default(3) // (1-5)
  supportReason   String?
  voterCategory   String?
  conversionPath  String?
  votedOnDay      Boolean     @default(false) // حالة التصويت الفعلي يوم الاقتراع
  checkedIn       Boolean     @default(false)
  checkedInAt     DateTime?

  // حقول الثقة والتقييم (من الوثيقة المرجعية)
  confidenceScore Int         @default(50)  // درجة الثقة (0-100)
  evaluationForm  String?     // JSON string — حقول نموذج التقييم
  notes           String?     // ملاحظات عامة

  // نمذجة الكتلة الصامتة والمترددين (Floating Voters Profile Clustering)
  predictedClusterId String?  // رقم المجموعة الديمغرافية للتنبؤ
  imputationWeights  String?  // JSON string — أوزان احتمالية التصويت

  // شجرة التجنيد الهرمية
  recruitedById String?       // الناخب الذي جنّد هذا الناخب
  recruitedBy   Voter?   @relation("VoterRecruitment", fields: [recruitedById], references: [id])
  recruits      Voter[]  @relation("VoterRecruitment")

  keyId       String
  electionKey ElectionKey @relation(fields: [keyId], references: [id])

  tribeId    String?
  tribe      Tribe?    @relation(fields: [tribeId], references: [id])
  subTribeId String?
  subTribe   SubTribe? @relation(fields: [subTribeId], references: [id])

  relationship    String?
  influenceRate   Int      @default(50) // نسبة التأثير المبدئية (0-100%)
  isPrimaryFollow Boolean  @default(true)
  lastContactDate DateTime?
  contactResult   String?
  nextAction      String?
  followUpDate    DateTime?

  // حقول التدقيق والتحقق المتقدمة
  latitude            Float?
  longitude           Float?
  gpsVerified         Boolean @default(false)
  isRegistryVerified  Boolean @default(false)
  registryVoterId     String?
  services            Service[]
  tasks               Task[]
  confidenceLogs      ConfidenceLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([keyId])
  @@index([tribeId])
  @@index([subTribeId])
  @@index([province])
  @@index([district])
  @@index([status])
  @@index([votedOnDay])
  @@index([confidenceScore])
  @@index([recruitedById])
}

// ====================================================================
// الخدمات (Service) — ربط بالناخب أو المفتاح
// ====================================================================

model Service {
  id                   String       @id @default(cuid())
  title                String
  category             String       // صحي | توظيف | رصف | مساعدات | ...
  description          String
  status               String       // PENDING | IN_PROGRESS | COMPLETED | CANCELLED
  cost                 Float        @default(0.0)
  priority             String       @default("NORMAL")
  assignedTo           String?
  estimatedVotesImpact Int          @default(0)
  keyId                String?
  electionKey          ElectionKey? @relation(fields: [keyId], references: [id])
  voterId              String?
  voter                Voter?       @relation(fields: [voterId], references: [id])
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@index([keyId])
  @@index([voterId])
  @@index([category])
  @@index([status])
}

// ====================================================================
// بيانات المفوضية لكل قضاء (21 قضاء) — 7 حقول: 6 يدوية + 1 تلقائي
// ====================================================================

model CommissionData {
  id               String   @id @default(cuid())
  province         String   @default("ذي قار")
  district         String   @unique // القضاء (21 قضاء)
  registeredVoters Int      @default(0) // الحقل 1: عدد الناخبين الكلي
  actualVoters     Int      @default(0) // الحقل 2: عدد المصوتين الكلي
  maleVoters       Int      @default(0) // الحقل 3: عدد أصوات الذكور
  femaleVoters     Int      @default(0) // الحقل 4: عدد أصوات الإناث
  pollingCenters   Int      @default(0) // الحقل 5: عدد مراكز الاقتراع
  ballotStations   Int      @default(0) // الحقل 6: عدد محطات الاقتراع
  // الحقل 7: نسبة المشاركة - حساب تلقائي = (actualVoters ÷ registeredVoters) × 100
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([province])
  @@index([district])
}

// ====================================================================
// المنافسون (Competitor) — تحليل القوى السياسية
// ====================================================================

model Competitor {
  id               String   @id @default(cuid())
  name             String
  party            String
  tribe            String
  baseDistrict     String
  estimatedVotes   Int      @default(0)
  strengthLevel    Int      @default(3) // (1-5)
  primaryArea      String?
  keyStrengths     String?
  keyWeaknesses    String?
  counterStrategy  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([baseDistrict])
}

// ====================================================================
// اتجاهات الرأي العام (SentimentTrend) — وسائل التواصل والاستطلاعات
// ====================================================================

model SentimentTrend {
  id        String   @id @default(cuid())
  source    String   // Facebook | Telegram | Local Survey
  sentiment String   // POSITIVE | NEGATIVE | NEUTRAL
  keywords  String   // JSON string
  score     Float
  region    String
  createdAt DateTime @default(now())

  @@index([source])
  @@index([region])
  @@index([createdAt])
}

// ====================================================================
// المتطوعون (Volunteer) والمهام (Task)
// ====================================================================

model Volunteer {
  id                  String   @id @default(cuid())
  fullName            String
  phone               String   @unique
  email               String?
  role                String   // FIELD_AGENT | LOGISTICS | MEDIA | COORDINATOR | ELECTION_DAY_OBSERVER
  district            String?
  area                String?
  notes               String?
  efficiencyScore     Int      @default(100)
  totalAssignedTasks  Int      @default(0)
  totalCompletedTasks Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tasks Task[]
}

model Task {
  id             String     @id @default(cuid())
  title          String
  description    String?
  priority       String     @default("NORMAL") // URGENT | HIGH | NORMAL | LOW
  status         String     @default("PENDING") // PENDING | IN_PROGRESS | COMPLETED | CANCELLED
  taskType       String     @default("FIELD")
  district       String?
  impactEstimate String?
  dueDate        DateTime?
  completedAt    DateTime?

  targetVoterId String?
  targetVoter   Voter?     @relation(fields: [targetVoterId], references: [id])

  assignedToId String?
  assignedTo   Volunteer? @relation(fields: [assignedToId], references: [id])

  electoralKeyId String?
  electoralKey   ElectionKey? @relation("ElectionKeyTasks", fields: [electoralKeyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([priority])
  @@index([district])
  @@index([assignedToId])
  @@index([electoralKeyId])
}

// ====================================================================
// تحديد المعدل (DB-backed — متعدد المثيلات ويصمد لإعادة التشغيل)
// ====================================================================

model RateLimit {
  key            String    @id
  count          Int       @default(0)
  lastAttemptAt  DateTime  @default(now())
  blockedUntil   DateTime?

  @@index([lastAttemptAt])
}

// ====================================================================
// إعدادات النظام (تفعيل/تعطيل وصول الزوار)
// ====================================================================

model SystemConfig {
  id        String   @id @default("system")
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

// ====================================================================
// سجل الثقة (ConfidenceLog) — تتبع تغيّرات الثقة لكل ناخب
// ====================================================================

model ConfidenceLog {
  id        String   @id @default(cuid())
  voterId   String
  voter     Voter    @relation(fields: [voterId], references: [id], onDelete: Cascade)
  oldScore  Int      // الدرجة القديمة
  newScore  Int      // الدرجة الجديدة
  change    Int      // مقدار التغيير (يمكن أن يكون سالباً)
  reason    String?  // سبب التغيير
  changedBy String?  // من قام بالتغيير
  createdAt DateTime @default(now())

  @@index([voterId])
  @@index([createdAt])
}

// ====================================================================
// حملات الرسائل القصيرة (SMSCampaign)
// ====================================================================

model SMSCampaign {
  id             String    @id @default(cuid())
  name           String
  message        String    // نص الرسالة
  filterType     String?   // DISTRICT | TRIBE | CLASSIFICATION | CONFIDENCE
  filterValue    String?   // قيمة الفلتر
  recipientCount Int       @default(0)
  status         String    @default("DRAFT") // DRAFT | SCHEDULED | SENT | FAILED
  scheduledAt    DateTime?
  sentAt         DateTime?
  provider       String    @default("TWILIO") // TWILIO | VONAGE
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status])
  @@index([scheduledAt])
}

// ====================================================================
// التنبيهات (Alert)
// ====================================================================

model Alert {
  id        String   @id @default(cuid())
  type      String   // INFO | WARNING | CRITICAL
  title     String
  message   String
  source    String?  // مصدر التنبيه
  isRead    Boolean  @default(false)
  relatedId String?  // معرّف الكيان المرتبط
  createdAt DateTime @default(now())

  @@index([type])
  @@index([isRead])
  @@index([createdAt])
}

// ====================================================================
// التحكم بالوصول (AccessControl)
// ====================================================================

model AccessControl {
  id          String   @id @default(cuid())
  label       String   @unique // تسمية كلمة المرور (زائر | مالك)
  password    String   // كلمة المرور المشفّرة
  isActive    Boolean  @default(true)
  lastChanged DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ====================================================================
// الإنذار المبكر (EarlyWarning)
// ====================================================================

model EarlyWarning {
  id              String       @id @default(cuid())
  electoralKeyId  String?
  electoralKey    ElectionKey? @relation(fields: [electoralKeyId], references: [id])
  warningType     String       // CONFIDENCE_DROP | LOYALTY_CHANGE | DEFECTION_RISK | FIELD_ISSUE
  severity        String       @default("MEDIUM") // LOW | MEDIUM | HIGH | CRITICAL
  description     String
  status          String       @default("ACTIVE") // ACTIVE | IN_PROGRESS | RESOLVED
  detectedAt      DateTime     @default(now())
  resolvedAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([electoralKeyId])
  @@index([severity])
  @@index([status])
  @@index([warningType])
}

// ====================================================================
// المؤشرات الديناميكية (DynamicIndicator)
// ====================================================================

model DynamicIndicator {
  id            String   @id @default(cuid())
  area          String   // المنطقة
  indicatorType String   // MOOD | TREND | STABILITY | TENSION
  value         Float    // القيمة الحالية
  previousValue Float    @default(0) // القيمة السابقة
  trend         String   @default("STABLE") // UP | STABLE | DOWN
  recordedAt    DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([area])
  @@index([indicatorType])
  @@index([recordedAt])
}

// ====================================================================
// المؤشرات المركبة (CompositeIndicator) — العشرة الرئيسية لكل منطقة
// ====================================================================

model CompositeIndicator {
  id           String   @id @default(cuid())
  area         String   // المنطقة
  eii          Float    @default(0) // مؤشر التأثير الانتخابي
  kri          Float    @default(0) // مؤشر موثوقية المفتاح
  vps          Float    @default(0) // درجة احتمالية التصويت
  drs          Float    @default(0) // درجة خطر الانشقاق
  campaignRoi  Float    @default(0) // عائد حملة الانتخاب
  api          Float    @default(0) // مؤشر اختراق المنطقة
  ewli         Float    @default(0) // مؤشر خسارة الإنذار المبكر
  gsi          Float    @default(0) // مؤشر القوة الجغرافية
  edri         Float    @default(0) // مؤشر جاهزية يوم الانتخاب
  efi          Float    @default(0) // مؤشر التوقع الانتخابي
  calculatedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([area])
  @@index([calculatedAt])
}

// ====================================================================
// النتائج الانتخابية التاريخية (ElectionResult)
// ====================================================================

model ElectionResult {
  id                String   @id @default(cuid())
  year              Int
  district          String
  totalVotes        Int      @default(0)
  validVotes        Int      @default(0)
  invalidVotes      Int      @default(0)
  participationRate Float    @default(0)
  winnerName        String?
  winnerVotes       Int      @default(0)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([year])
  @@index([district])
}

// ====================================================================
// البيانات المرجعية للمحافظة (Read-Only) — المؤشرات العامة لمحافظة ذي قار
// ====================================================================

model ProvinceReference {
  id                  String   @id @default(cuid())
  province            String   @unique @default("ذي قار")
  totalRegisteredVoters Int    @default(1099438)
  totalActualVoters   Int      @default(538390)
  generalTurnout      Float    @default(48.97)
  maleVoters          Int      @default(322970)
  femaleVoters        Int      @default(215420)
  pollingCentersCount Int      @default(527)
  ballotStationsCount Int      @default(2212)
  lastRegistryUpdate  DateTime?
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

